{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "out/tsconfig.web.tsbuildinfo",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/renderer/src/app/*"]
    }
  },
  "include": [
    "src/renderer/src/**/*",
    "src/renderer/index.html"
  ]
}
